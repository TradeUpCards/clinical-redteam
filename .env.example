# Clinical Red Team Platform — environment configuration
#
# Copy this file to .env and fill in real values. .env is gitignored.
# Never commit real secrets. The platform refuses to start if required
# vars are missing (validated in clinical_redteam/__init__.py at boot).
#
# Architectural references for each section are noted inline.

# ---------------------------------------------------------------------------
# OpenRouter — LLM routing layer for ALL agent calls (ARCH §8.2.6)
# ---------------------------------------------------------------------------
# Single auth + bill + telemetry surface for Red Team / Judge / Documentation.
# Get a key at https://openrouter.ai/keys. Phase 1 budget: $5-15 in credit.
OPENROUTER_API_KEY=

# Optional override; default is the public OpenRouter endpoint.
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1


# ---------------------------------------------------------------------------
# Model selection per agent (ARCH §8.2 — selection-criteria-first, configurable)
# ---------------------------------------------------------------------------
# Model IDs are tactical config — the CRITERIA in ARCH §8.2.{1-4} are the
# architectural decision. Iterate IDs based on real cost/quality data from
# Phase 1 runs. Comma-separated lists for fallback chains.

# Red Team — permissive safety posture, strong instruction-following, cheap (§8.2.1).
# Try in order; first available wins. Open-weight models preferred over frontier
# because frontier increasingly refuses offensive-security prompts.
RED_TEAM_MODEL=cognitivecomputations/dolphin-mixtral-8x22b
RED_TEAM_FALLBACK_MODELS=qwen/qwen-2.5-72b-instruct,deepseek/deepseek-chat,meta-llama/llama-3.3-70b-instruct

# Judge — high accuracy, cross-provider from Red Team to avoid shared failure
# modes, structured-output reliability (§8.2.2). Frontier strongly preferred.
JUDGE_MODEL=anthropic/claude-sonnet-4
JUDGE_FALLBACK_MODEL=openai/gpt-4o

# Documentation — template adherence, PHI-safe output (§8.2.3).
DOCUMENTATION_MODEL=anthropic/claude-sonnet-4
DOCUMENTATION_FALLBACK_MODEL=anthropic/claude-haiku-4-5

# Orchestrator — MVP uses pure Python rules; LLM augmentation is Phase 2 (§8.2.4).
# Leave empty to disable LLM calls in the Orchestrator.
ORCHESTRATOR_MODEL_OPTIONAL=


# ---------------------------------------------------------------------------
# Target Co-Pilot — AgentForge Clinical Co-Pilot (ARCH §1, §2.1)
# ---------------------------------------------------------------------------
# This is the system under attack. Every call is HMAC-signed (ARCH §2.1 —
# no unsigned fallback path). HMAC secret must match the target's
# OPENEMR_HMAC_SECRET deployed env. Out-of-scope targets are HARD-REFUSED.
RED_TEAM_TARGET_URL=https://142-93-242-40.nip.io
RED_TEAM_TARGET_HMAC_SECRET=

# Target-side identity the platform signs requests as. The Co-Pilot's PHP
# integration module normally derives these from $_SESSION; attacking the
# agent service directly means WE supply them in the signed body.
#
# RED_TEAM_TARGET_USER_ID: integer clinician id; use admin (1) for parity
#   with W2 eval suite cases unless you've set up a dedicated red-team user.
# RED_TEAM_TARGET_SENTINEL_PATIENT_IDS: comma-separated list of sentinel
#   patient IDs (999100-999999 range per project hard rule — NEVER real PHI).
#   Need at least 2 distinct IDs for cross-patient leakage attacks (C-7
#   rediscovery; ARCH §9.4 + THREAT_MODEL.md §1.5).
RED_TEAM_TARGET_USER_ID=1
RED_TEAM_TARGET_SENTINEL_PATIENT_IDS=999100,999999

# HMAC signing window. Co-Pilot rejects timestamps more than this many
# seconds off its own clock (ARCH §2.1 + AgentForge agent.py:_HMAC_MAX_AGE_SECONDS).
# Keep equal to or smaller than the target's window.
HMAC_MAX_AGE_SECONDS=30


# ---------------------------------------------------------------------------
# Cost guards (ARCH §8.1)
# ---------------------------------------------------------------------------
# Hard cap halts the daemon. Soft cap (50% of hard cap) reduces Red Team
# scope to single-turn / fewer mutations. Default $10 for dev runs.
MAX_SESSION_COST_USD=10


# ---------------------------------------------------------------------------
# Observability — Langfuse hobby tier (presearch.html §10, ARCH §9.1)
# ---------------------------------------------------------------------------
# Per-agent spans + PHI scrubber pre-send. Hobby tier is free up to volume
# caps that comfortably cover MVP + Final week traffic. Get keys at
# https://cloud.langfuse.com/ (or self-host).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com


# ---------------------------------------------------------------------------
# Runtime / persistence (ARCH §9.1 — filesystem checkpoints)
# ---------------------------------------------------------------------------
# Eval seed cases + Judge criteria YAMLs live under EVALS_DIR.
# Per-run results (manifest.json, attacks, verdicts, cost ledger, vuln drafts)
# live under RESULTS_DIR/<run-id>/.
EVALS_DIR=./evals
RESULTS_DIR=./evals/results

# Log verbosity for the daemon. Production: INFO. Dev: DEBUG.
LOG_LEVEL=INFO


# ---------------------------------------------------------------------------
# Continuous-mode operational tuning (ARCH §10.2)
# ---------------------------------------------------------------------------
# These shape Orchestrator halt + routing behavior in the continuous-mode
# daemon (Phase 1b). MVP defaults are conservative; iterate from run data.

# Cap per attack chain — when a chain reaches this depth without converging
# to FAIL, Orchestrator marks the chain `inconclusive` and rotates category
# (ARCH §10.2 — "Mutation diversity collapse").
MAX_MUTATION_DEPTH=5

# Halt the daemon when (open_findings / session_cost_usd) drops below this
# floor across a sliding window — signals the daemon is spending budget
# without producing signal (ARCH §10.2).
SIGNAL_TO_COST_FLOOR=0.05

# Judge marks `human_escalation_required=True` when confidence is below
# this threshold OR when verdict is non-pass with empty criteria_triggered
# (ARCH §12.2 — anomalous Judge output).
JUDGE_CONFIDENCE_THRESHOLD=0.7

# Sanity cap on iterations even when cost budget would allow more.
# Complementary to MAX_SESSION_COST_USD — whichever fires first wins.
MAX_ITERATIONS_PER_SESSION=100
